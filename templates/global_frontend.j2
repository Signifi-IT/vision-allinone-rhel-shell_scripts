frontend http_frontend
    mode http

    # HTTP bind
    bind *:80

    # Capture and log the User-Agent header
    capture request header User-Agent len 200
    capture request header Host len 100

    # Timeouts
    timeout client 1m

    # Redirect HTTP to HTTPS
    http-request redirect scheme https code 301 if !{ ssl_fc }

frontend https_frontend
    mode http

    # HTTPS bind
    bind *:443 ssl crt /etc/haproxy/certs/ alpn h2,http/1.1

    # Capture and log the User-Agent header
    capture request header User-Agent len 200
    capture request header Host len 100

    # Timeouts
    timeout client 1m

    # Override X-Forwarded-For with the real IP of the client to prevent spoofing
    http-request del-header X-Forwarded-For
    http-request set-header X-Forwarded-For %[src]
    http-request set-header X-Forwarded-Proto https

    # HAProxy stats ACLs
    acl allowed_stats src {{ HAPROXY_ALLOWED_STATS_IPS | join(' ') }}

    # Flag stats requests before any path modifications
    http-request set-var(txn.is_stats) bool(true) if { path -i /haproxy-stats }

    # Deny unauthorized access
    http-request deny if { var(txn.is_stats) -m bool } !allowed_stats

    # Rewrite stats URI for the stats backend
    http-request set-path / if { var(txn.is_stats) -m bool }

    # Detect static assets during request phase
    http-request set-var(txn.is_static_asset) bool(true) if { path_end -i .jpg .jpeg .png .gif .webp .svg .ico .mp4 .webm .mov }

    # Route to stats backend
    use_backend haproxy_stats_backend if { var(txn.is_stats) -m bool } allowed_stats

    # Dynamic host routing
    use_backend %[req.hdr(host),lower,map(/etc/haproxy/maps/hosts.map)]

    # Optional safety fallback
    default_backend unknown_host_backend

    # Cache headers during response phase
    http-response set-header Cache-Control "public, max-age=31536000, immutable" if { var(txn.is_static_asset) -m bool }
    http-response set-header Expires %[date(31536000)] if { var(txn.is_static_asset) -m bool }

    # HSTS (2 years, preload)
    http-response set-header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"

    # Security Headers (global)
    http-response set-header Access-Control-Allow-Origin "*"
    http-response set-header X-Frame-Options "SAMEORIGIN"
    http-response set-header X-Content-Type-Options "nosniff"
    http-response set-header Referrer-Policy "no-referrer"
    http-response set-header X-XSS-Protection "1; mode=block"
    http-response del-header X-Powered-By

    # Content Security Policy
    http-response set-header Content-Security-Policy "frame-ancestors 'self'"
